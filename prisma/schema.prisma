enum Platforms {
  android
  ios
}

model DeviceToken {
  id             String    @id @default(uuid())
  platform       Platforms
  deviceToken    String    @unique
  snsEndpointArn String
  subscriptionArn String  
  enabled        Boolean
  lastUsedAt     DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, snsEndpointArn])
  @@index([deviceToken])
  @@map("device_token")
}

model User {
  id             String           @id
  name           String
  email          String
  emailVerified  Boolean
  image          String?
  createdAt      DateTime
  currency       Currencies
  updatedAt      DateTime
  deletedAt      DateTime?
  device         DeviceToken[]
  sessions       Session[]
  accounts       Account[]
  Budgets        Budgets[]
  Categories     Categories[]
  PaymentMethods PaymentMethods[]
  Transactions   Transactions[]

  @@unique([email])
  @@index([email, deletedAt])
  @@index([id, deletedAt])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Budgets {
  id           String         @id
  amount       Decimal        @db.Decimal(12, 2)
  year         Int
  budgetMonth  Months
  currency     Currencies
  userId       String
  period       Int
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime
  updatedAt    DateTime
  Transactions Transactions[]

  @@unique([userId, period])
  @@unique([userId, budgetMonth, year])
  @@map("budgets")
}

model Categories {
  id           String         @id
  name         String         @db.VarChar(30)
  color        String
  emoji        String
  description  String         @db.VarChar(50)
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime
  updatedAt    DateTime
  Transactions Transactions[]

  @@unique([userId, color])
  @@unique([userId, name])
  @@unique([userId, emoji])
  @@map("categories")
}

model PaymentMethods {
  id           String         @id
  name         String         @db.VarChar(30)
  color        String
  emoji        String
  description  String         @db.VarChar(50)
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime
  updatedAt    DateTime
  Transactions Transactions[]

  @@unique([userId, name])
  @@unique([userId, color])
  @@unique([userId, emoji])
  @@map("payment_methods")
}

model Transactions {
  id     String  @id
  amount Decimal @db.Decimal(12, 2)

  transactionDate DateTime
  note            String?         @db.VarChar(50)
  transactionType TransactionType
  currency        Currencies
  categoryId      String
  category        Categories      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  paymentMethodId String
  paymentMethod   PaymentMethods @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  budgetId String
  budget   Budgets @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  createdAt DateTime
  updatedAt DateTime

  @@index([budgetId, categoryId, currency])
  @@index([userId, transactionDate, currency])
  @@map("transactions")
}
